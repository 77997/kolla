FROM {{ namespace }}/{{ image_prefix }}base:{{ tag }}
{% block labels %}
LABEL maintainer="{{ maintainer }}" name="{{ image_name }}" build-date="{{ build_date }}"
{% endblock %}

{% block opensearch_header %}{% endblock %}

{% import "macros.j2" as macros with context %}

{{ macros.configure_user(name='opensearch', shell='/bin/bash', homedir='/usr/share/opensearch') }}

{% if base_arch == 'ppc64le' %}

{% set opensearch_packages = [
    'openjdk-21-jre-headless'
] %}

ENV OPENSEARCH_INITIAL_ADMIN_PASSWORD="Kolla24OpenSearch"

{{ macros.install_packages(opensearch_packages | customizable("packages")) }}

{# Tarball is pre-built outside Docker by CI and placed in the build context.
   Docker's legacy builder cannot COPY --from a cross-platform stage, so we
   build with Gradle natively on the amd64 CI runner. OpenSearch is pure Java
   bytecode, so the resulting tarball is platform-independent. #}
COPY opensearch-min-*.tar.gz /tmp/
RUN tar -xzf /tmp/opensearch-min-*.tar.gz -C /usr/share \
    && mv /usr/share/opensearch-* /usr/share/opensearch \
    && mkdir -p /etc/opensearch \
    && chown -R opensearch:opensearch /usr/share/opensearch \
    && chown -R opensearch:opensearch /etc/opensearch

{% else %}

{{ macros.enable_extra_repos(['opensearch']) }}

    {% set opensearch_packages = [
        'opensearch'
    ] %}

ENV OPENSEARCH_INITIAL_ADMIN_PASSWORD="Kolla24OpenSearch"

{{ macros.install_packages(opensearch_packages | customizable("packages")) }} \
    && chown -R opensearch:opensearch /usr/share/opensearch \
    && rm -f /etc/opensearch/*.pem \
    && rm -f /etc/opensearch/securityadmin_demo.sh

{% endif %}

COPY extend_start.sh /usr/local/bin/kolla_extend_start
RUN chmod 755 /usr/local/bin/kolla_extend_start

{{ macros.kolla_patch_sources() }}

{% block opensearch_footer %}{% endblock %}
{% block footer %}{% endblock %}

USER opensearch
