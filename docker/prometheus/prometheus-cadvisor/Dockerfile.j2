FROM {{ namespace }}/{{ image_prefix }}prometheus-base:{{ tag }}
{% block labels %}
LABEL maintainer="{{ maintainer }}" name="{{ image_name }}" build-date="{{ build_date }}"
{% endblock %}

{% block prometheus_cadvisor_header %}{% endblock %}

{% import "macros.j2" as macros with context %}

{% block prometheus_cadvisor_install %}
{% if base_arch == 'ppc64le' %}
{# Binary is pre-built outside Docker by CI (native amd64 Go cross-compilation).
   The binary must exist in the build context (written by CI pre-build step). #}
COPY cadvisor /opt/cadvisor
RUN chmod 0755 /opt/cadvisor
{% else %}
ADD prometheus-cadvisor-archive /prometheus-cadvisor-source

RUN cp /prometheus-cadvisor-source /opt/cadvisor \
    && chmod 0755 /opt/cadvisor
{% endif %}
{% endblock %}

{{ macros.kolla_patch_sources() }}

{% block prometheus_cadvisor_footer %}{% endblock %}
{% block footer %}{% endblock %}
